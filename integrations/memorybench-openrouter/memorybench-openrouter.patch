new file mode 100644
index 0000000..77e3e80
--- /dev/null
+++ b/src/judges/openrouter.test.ts
@@ -0,0 +1,27 @@
+import { describe, expect, test } from "bun:test"
+import { createJudge, getAvailableJudges } from "./index"
+
+describe("OpenRouter judge registration", () => {
+  test("is discoverable and validates model aliases without a network request", async () => {
+    expect(getAvailableJudges()).toContain("openrouter")
+    const judge = createJudge("openrouter")
+    await judge.initialize({
+      apiKey: "synthetic-key",
+      model: "openrouter:openai/gpt-4.1-mini",
+    })
+    expect(judge.name).toBe("openrouter")
+    expect(judge.getModel()).toBeDefined()
+  })
+
+  test("rejects missing credentials and non-OpenRouter model aliases", async () => {
+    await expect(
+      createJudge("openrouter").initialize({
+        apiKey: "",
+        model: "openrouter:openai/gpt-4.1-mini",
+      })
+    ).rejects.toThrow()
+    await expect(
+      createJudge("openrouter").initialize({ apiKey: "synthetic-key", model: "gpt-4o" })
+    ).rejects.toThrow()
+  })
+})
diff --git a/src/judges/openrouter.ts b/src/judges/openrouter.ts
new file mode 100644
index 0000000..7643118
--- /dev/null
+++ b/src/judges/openrouter.ts
@@ -0,0 +1,51 @@
+import { createOpenAI } from "@ai-sdk/openai"
+import { generateText } from "ai"
+import type { Judge, JudgeConfig, JudgeInput, JudgeResult } from "../types/judge"
+import type { ProviderPrompts } from "../types/prompts"
+import { buildJudgePrompt, parseJudgeResponse, getJudgePrompt } from "./base"
+import { logger } from "../utils/logger"
+import { getModelConfig, ModelConfig, DEFAULT_JUDGE_MODELS } from "../utils/models"
+
+export class OpenRouterJudge implements Judge {
+  name = "openrouter"
+  private modelConfig: ModelConfig | null = null
+  private client: ReturnType<typeof createOpenAI> | null = null
+
+  async initialize(config: JudgeConfig): Promise<void> {
+    if (!config.apiKey) throw new Error("OPENROUTER_API_KEY or OPEN_ROUTER_KEY is required")
+    this.client = createOpenAI({
+      apiKey: config.apiKey,
+      baseURL: config.baseUrl || "https://openrouter.ai/api/v1",
+    })
+    const modelAlias = config.model || DEFAULT_JUDGE_MODELS.openrouter
+    this.modelConfig = getModelConfig(modelAlias)
+    if (this.modelConfig.provider !== "openrouter") {
+      throw new Error("OpenRouter judge models must use openrouter:<provider/model>")
+    }
+    logger.info(
+      `Initialized OpenRouter judge with model: ${this.modelConfig.displayName} (${this.modelConfig.id})`
+    )
+  }
+
+  async evaluate(input: JudgeInput): Promise<JudgeResult> {
+    if (!this.client || !this.modelConfig) throw new Error("Judge not initialized")
+    const params: Record<string, unknown> = {
+      model: this.client(this.modelConfig.id),
+      prompt: buildJudgePrompt(input),
+      maxTokens: this.modelConfig.defaultMaxTokens,
+    }
+    const { text } = await generateText(params as Parameters<typeof generateText>[0])
+    return parseJudgeResponse(text)
+  }
+
+  getPromptForQuestionType(questionType: string, providerPrompts?: ProviderPrompts): string {
+    return getJudgePrompt(questionType, providerPrompts)
+  }
+
+  getModel() {
+    if (!this.client || !this.modelConfig) throw new Error("Judge not initialized")
+    return this.client(this.modelConfig.id)
+  }
+}
+
+export default OpenRouterJudge
