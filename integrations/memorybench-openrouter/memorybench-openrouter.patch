@@ -0,0 +1,15 @@
+import { describe, expect, test } from "bun:test"
+import { getModelConfig, getModelProvider } from "./models"
+
+describe("OpenRouter model aliases", () => {
+  test("preserve the routed provider/model id", () => {
+    const config = getModelConfig("openrouter:anthropic/claude-3.5-sonnet")
+    expect(config.provider).toBe("openrouter")
+    expect(config.id).toBe("anthropic/claude-3.5-sonnet")
+    expect(getModelProvider("openrouter:openai/gpt-4.1-mini")).toBe("openrouter")
+  })
+
+  test("rejects an empty routed model", () => {
+    expect(() => getModelConfig("openrouter:")).toThrow()
+  })
+})
